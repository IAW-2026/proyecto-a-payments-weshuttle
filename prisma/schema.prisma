generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentProvider {
  MERCADO_PAGO
}

enum PayoutAccountStatus {
  ACTIVE
  INACTIVE
  REJECTED
}

enum PricingRuleDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CheckoutSessionStatus {
  CREATED
  PENDING
  PAID
  DENIED
  CANCELED
  EXPIRED
}

enum ChargeStatus {
  PENDING
  PAID
  DENIED
  CANCELED
  EXPIRED
  FAILED
}

enum CreditMovementType {
  CREDIT_GRANTED
  CREDIT_APPLIED
  MANUAL_ADJUSTMENT
}

enum PoolPriceFinalizationJobReason {
  POOL_LOCKED
  NO_DRIVER_ASSIGNED
}

enum PoolPriceFinalizationJobStatus {
  STARTED
  COMPLETED
  FAILED
}

enum PoolPriceFinalizationDiscountType {
  OCCUPANCY_DISCOUNT
  NO_DRIVER_CREDIT
}

enum SettlementStatus {
  PENDING
  COMPLETED
  FAILED
}

model ConnectionTest {
  id        String   @id @default(cuid())
  label     String   @default("ok")
  createdAt DateTime @default(now())
}

model PayoutAccount {
  id               String              @id @default(cuid())
  driverUserId     String              @map("driver_user_id")
  provider         PaymentProvider
  accountReference String              @unique @map("account_reference")
  alias            String?
  status           PayoutAccountStatus

  settlements Settlement[]

  @@index([driverUserId, status])
  @@map("payout_accounts")
}

model PricingRule {
  id            String                  @id @default(cuid())
  destinationId String?                 @map("destination_id")
  basePrice     Decimal                 @map("base_price") @db.Decimal(10, 2)
  minPassengers Int                     @map("min_passengers")
  maxPassengers Int                     @map("max_passengers")
  discountType  PricingRuleDiscountType @map("discount_type")
  discountValue Decimal                 @map("discount_value") @db.Decimal(10, 2)
  active        Boolean

  poolPriceFinalizationJobs PoolPriceFinalizationJob[]

  @@index([destinationId, active, minPassengers, maxPassengers])
  @@index([active])
  @@map("pricing_rules")
}

model CheckoutSession {
  id                        String                @id @default(cuid())
  reservationId             String                @map("reservation_id")
  poolId                    String                @map("pool_id")
  passengerUserId           String                @map("passenger_user_id")
  maxPrice                  Decimal               @map("max_price") @db.Decimal(10, 2)
  availableCreditAtCreation Decimal               @map("available_credit_at_creation") @db.Decimal(10, 2)
  creditApplied             Decimal               @map("credit_applied") @db.Decimal(10, 2)
  amountToCharge            Decimal               @map("amount_to_charge") @db.Decimal(10, 2)
  currency                  String
  status                    CheckoutSessionStatus
  provider                  PaymentProvider
  checkoutUrl               String?               @map("checkout_url")
  mercadoPagoPreferenceId   String?               @map("mercado_pago_preference_id")
  mercadoPagoInitPoint      String?               @map("mercado_pago_init_point")
  expiresAt                 DateTime?             @map("expires_at")
  createdAt                 DateTime              @default(now()) @map("created_at")
  updatedAt                 DateTime              @updatedAt @map("updated_at")

  charges Charge[]

  @@index([reservationId, status])
  @@index([passengerUserId, status])
  @@index([poolId])
  @@map("checkout_sessions")
}

model Charge {
  id                         String      @id @default(cuid())
  transactionId              String      @unique @map("transaction_id")
  checkoutSessionId          String?     @map("checkout_session_id")
  poolPriceFinalizationJobId String?     @map("pool_price_finalization_job_id")
  poolId                     String      @map("pool_id")
  reservationId              String      @map("reservation_id")
  passengerUserId            String      @map("passenger_user_id")
  maxPrice                   Decimal     @map("max_price") @db.Decimal(10, 2)
  creditApplied              Decimal     @map("credit_applied") @db.Decimal(10, 2)
  amountCharged              Decimal     @map("amount_charged") @db.Decimal(10, 2)
  finalTripPrice             Decimal?    @map("final_trip_price") @db.Decimal(10, 2)
  creditGranted              Decimal     @map("credit_granted") @db.Decimal(10, 2)
  currency                   String
  status                     ChargeStatus
  provider                   PaymentProvider
  rejectionReason            String?     @map("rejection_reason")
  processedAt                DateTime?   @map("processed_at")
  createdAt                  DateTime    @default(now()) @map("created_at")

  checkoutSession          CheckoutSession?          @relation(fields: [checkoutSessionId], references: [id])
  poolPriceFinalizationJob PoolPriceFinalizationJob? @relation(fields: [poolPriceFinalizationJobId], references: [id])
  creditMovements          CreditMovement[]

  @@index([reservationId, status])
  @@index([poolId, status])
  @@index([passengerUserId, status])
  @@index([checkoutSessionId])
  @@index([poolPriceFinalizationJobId])
  @@map("charges")
}

model CreditAccount {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  balance   Decimal  @db.Decimal(10, 2)
  currency  String
  updatedAt DateTime @updatedAt @map("updated_at")

  movements CreditMovement[]

  @@map("credit_accounts")
}

model CreditMovement {
  id                         String             @id @default(cuid())
  creditAccountId            String             @map("credit_account_id")
  userId                     String             @map("user_id")
  type                       CreditMovementType
  amount                     Decimal            @db.Decimal(10, 2)
  currency                   String
  reservationId              String?            @map("reservation_id")
  poolId                     String?            @map("pool_id")
  chargeId                   String?            @map("charge_id")
  poolPriceFinalizationJobId String?            @map("pool_price_finalization_job_id")
  description                String?
  createdAt                  DateTime           @default(now()) @map("created_at")

  creditAccount            CreditAccount             @relation(fields: [creditAccountId], references: [id], onDelete: Cascade)
  charge                   Charge?                   @relation(fields: [chargeId], references: [id])
  poolPriceFinalizationJob PoolPriceFinalizationJob? @relation(fields: [poolPriceFinalizationJobId], references: [id])

  @@index([creditAccountId])
  @@index([userId, createdAt])
  @@index([reservationId])
  @@index([poolId])
  @@index([chargeId])
  @@index([poolPriceFinalizationJobId])
  @@map("credit_movements")
}

model PoolPriceFinalizationJob {
  id                String                             @id @default(cuid())
  poolId            String                             @map("pool_id")
  reason            PoolPriceFinalizationJobReason
  currentPassengers Int                                @map("current_passengers")
  pricingRuleId     String?                            @map("pricing_rule_id")
  basePrice         Decimal                            @map("base_price") @db.Decimal(10, 2)
  finalPrice        Decimal?                           @map("final_price") @db.Decimal(10, 2)
  discountType      PoolPriceFinalizationDiscountType? @map("discount_type")
  discountValue     Decimal?                           @map("discount_value") @db.Decimal(10, 2)
  currency          String
  status            PoolPriceFinalizationJobStatus
  startedAt         DateTime                           @map("started_at")
  finishedAt        DateTime?                          @map("finished_at")

  pricingRule     PricingRule?      @relation(fields: [pricingRuleId], references: [id])
  charges         Charge[]
  creditMovements CreditMovement[]

  @@index([poolId, status])
  @@index([poolId, reason])
  @@index([pricingRuleId])
  @@map("pool_price_finalization_jobs")
}

model Settlement {
  id             String           @id @default(cuid())
  poolId          String           @unique @map("pool_id")
  driverUserId    String           @map("driver_user_id")
  payoutAccountId String?          @map("payout_account_id")
  amount          Decimal          @db.Decimal(10, 2)
  currency        String
  status          SettlementStatus
  settledAt       DateTime?        @map("settled_at")

  payoutAccount PayoutAccount? @relation(fields: [payoutAccountId], references: [id])

  @@index([driverUserId, status])
  @@index([payoutAccountId])
  @@map("settlements")
}
